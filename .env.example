# Database
DATABASE_URL=

# AI (Anthropic — for Break Down / Draft Desc / Suggest Priority buttons)
ANTHROPIC_API_KEY=

# MCP auth — agents must send this as Bearer token to /mcp
MCP_SECRET=

# GitHub — PAT with contents:read scope, used for YAML sync from repos
GITHUB_TOKEN=

# Frontend build-time var — set in Railway before first frontend deploy
VITE_API_BASE_URL=http://localhost:3001

# Set automatically by Railway
PORT=3001
